# GitHub token with repo read access (required for collect)
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub organization name (auto-detected from git remote if not set)
# GH_ORG=your-org-name

# This repository name (excluded from collection, auto-detected if not set)
# GH_REPO=agent-skill-harbor

# Slack Incoming Webhook URL for builtin.notify-slack (preferred over config/harbor.yaml)
# HARBOR_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
